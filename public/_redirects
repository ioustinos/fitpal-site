# API routes — must come BEFORE the SPA fallback, or /* eats them.
# Kept here (instead of in netlify.toml) because Netlify's resolved order
# puts _redirects rules first and we need /api/* to win.
/api/*  /.netlify/functions/:splat  200

# WEC-303: SEO crawler endpoints. Same rationale — must come BEFORE the
# SPA fallback or Lighthouse + Googlebot get the index.html HTML when
# they ask for plain text/XML. Status 200 (not 301) so the served
# content is from the actual file at that path, not the redirect target.
/robots.txt   /robots.txt   200
/sitemap.xml  /sitemap.xml  200

# SPA fallback — catch-all, last.
/*      /index.html                 200
